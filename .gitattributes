# Normalize line endings for text files
* text=auto

# ─── Large Model Files → Git LFS ─────────────────────────
*.h5 filter=lfs diff=lfs merge=lfs -text
*.weights.h5 filter=lfs diff=lfs merge=lfs -text
*.keras filter=lfs diff=lfs merge=lfs -text

# ─── Dataset Images → Git LFS ────────────────────────────
Training/** filter=lfs diff=lfs merge=lfs -text
Testing/** filter=lfs diff=lfs merge=lfs -text

# ─── Screenshot/Image assets ─────────────────────────────
images/*.png filter=lfs diff=lfs merge=lfs -text
images/*.jpg filter=lfs diff=lfs merge=lfs -text
